# ============================================
# SUPABASE (OBLIGATORIO) — NO BORRAR ESTAS CLAVES
# ============================================
# IMPORTANTE:
# - No elimines estas variables del archivo .env.local
# - NEXT_PUBLIC_SUPABASE_ANON_KEY debe ser la clave "anon", NUNCA "service_role"
# - Nunca publiques/compartas la clave service_role; si se expone, ROTAR de inmediato
# Obtener de: https://app.supabase.com → Tu Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ============================================
# CLOUDINARY (OBLIGATORIO para imágenes)
# ============================================
# Obtener de: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ============================================
# MERCADOPAGO (OPCIONAL - solo si usas pagos)
# ============================================
# Obtener de: https://www.mercadopago.com.mx/developers → Credenciales
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=tu-public-key
MERCADOPAGO_ACCESS_TOKEN=tu-access-token
MERCADOPAGO_WEBHOOK_SECRET=tu-webhook-secret

# ============================================
# EMAIL - RESEND (OPCIONAL)
# ============================================
# Obtener de: https://resend.com → API Keys
RESEND_API_KEY=re_tu-api-key-aqui
EMAIL_FROM=contacto@tudominio.com
EMAIL_FROM_NAME=Tu App

# ============================================
# URL DEL SITIO (IMPORTANTE)
# ============================================
# En desarrollo:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# En producción (actualizar después del primer despliegue):
# NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app
